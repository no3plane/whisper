{
  "name": "whisper-reading-copilot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=24 <25"
  },
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint . --deny-warnings",
    "lint:types": "tsc --noEmit",
    "harness:check": "node scripts/check-harness.mjs",
    "check": "pnpm harness:check && pnpm format:check && pnpm lint && pnpm lint:types && pnpm test && pnpm build",
    "hooks:install": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@base-ui/react": "^1.6.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ai": "^4.3.16",
    "electron": "43.1.0",
    "electron-log": "^5.4.4",
    "electron-vite": "^3.1.0",
    "github-slugger": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "typescript": "^5.8.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "jsdom": "^26.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "1.73.0",
    "vite": "^6.2.6",
    "vitest": "^3.1.1"
  }
}
