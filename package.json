{
  "name": "whisper-reading-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "predev": "pnpm run rebuild:native",
    "rebuild:native": "npm_config_runtime=electron npm_config_target=35.7.5 npm_config_disturl=https://electronjs.org/headers npm_config_build_from_source=true npm rebuild better-sqlite3",
    "rebuild:node": "npm_config_runtime=node npm_config_build_from_source=true npm rebuild better-sqlite3",
    "pretest": "pnpm run rebuild:node",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:types": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.22",
    "@assistant-ui/react": "^0.14.26",
    "@assistant-ui/react-markdown": "^0.14.5",
    "@vitejs/plugin-react": "^4.3.4",
    "ai": "^4.3.16",
    "better-sqlite3": "^11.10.0",
    "electron": "^35.2.0",
    "electron-log": "^5.4.4",
    "electron-vite": "^3.1.0",
    "github-slugger": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "typescript": "^5.8.3",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "jsdom": "^26.0.0",
    "vite": "^6.2.6",
    "vitest": "^3.1.1"
  }
}
